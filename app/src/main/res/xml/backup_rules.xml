<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <!-- Never back up translation-provider secrets/endpoints. EncryptedSharedPreferences is also
         keyed to this device's Keystore, so a restored copy would be undecryptable. -->
    <exclude domain="sharedpref" path="translator_keys_enc.xml"/>
    <exclude domain="sharedpref" path="translator_keys.xml"/>
    <exclude domain="sharedpref" path="translator_endpoints.xml"/>
</full-backup-content>