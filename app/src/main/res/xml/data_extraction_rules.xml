<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Translation-provider secrets/endpoints must never leave the device. -->
        <exclude domain="sharedpref" path="translator_keys_enc.xml"/>
        <exclude domain="sharedpref" path="translator_keys.xml"/>
        <exclude domain="sharedpref" path="translator_endpoints.xml"/>
        <!-- Premium entitlement cache; source of truth is Play Billing. -->
        <exclude domain="sharedpref" path="entitlement.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="translator_keys_enc.xml"/>
        <exclude domain="sharedpref" path="translator_keys.xml"/>
        <exclude domain="sharedpref" path="translator_endpoints.xml"/>
        <exclude domain="sharedpref" path="entitlement.xml"/>
    </device-transfer>
</data-extraction-rules>